{
  "expo": {
    "name": "아침일기",
    "slug": "morning-diary",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/img-logo-login.png",
    "scheme": "morningdiary",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "displayName": "아침일기",
      "supportsTablet": true,
      "bundleIdentifier": "com.mymorningdiary.morningdiary"
    },
    "android": {
      "displayName": "아침일기",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.mymorningdiary.morningdiary"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "extraMavenRepos": [
              "https://devrepo.kakao.com/nexus/content/groups/public/"
            ]
          }
        }
      ],
      [
        "@react-native-kakao/core",
        {
          "nativeAppKey": "162f6841f726fc6ff11498b56b4030a",
          "android": {
           "authCodeHandlerActivity": true
          },
          "ios": {
           "handleKakaoOpenUrl": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
